---
interface Props {
  label: string;
  title: string;
  body: string;
  command: string;
  tone?: "mint" | "violet" | "lime" | "blue";
}

const { label, title, body, command, tone = "mint" } = Astro.props;
---

<article class:list={["use-card", `use-card--${tone}`]}>
  <div class="use-card__marker" aria-hidden="true"></div>
  <p class="eyebrow">{label}</p>
  <h3>{title}</h3>
  <p>{body}</p>
  <code>{command}</code>
</article>
