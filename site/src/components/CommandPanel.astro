---
interface CommandItem {
  command: string;
  note?: string;
}

interface Props {
  eyebrow: string;
  title: string;
  items: CommandItem[];
  tone?: "mint" | "violet" | "lime" | "blue";
}

const { eyebrow, title, items, tone = "mint" } = Astro.props;
---

<article class:list={["command-panel", `command-panel--${tone}`]}>
  <p class="eyebrow">{eyebrow}</p>
  <h3>{title}</h3>
  <div class="terminal-lines" aria-label={title}>
    {items.map((item) => (
      <div class="terminal-line">
        <code>{item.command}</code>
        {item.note && <span>{item.note}</span>}
      </div>
    ))}
  </div>
</article>
