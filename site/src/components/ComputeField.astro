<figure class="compute-field chat-illustration" aria-label="Animated coding agent session running modal-uv on Modal">
  <div class="agent-terminal" aria-label="Animated opencode-style coding agent session">
    <div class="agent-terminal__bar">
      <div class="terminal-lights" aria-hidden="true"><span></span><span></span><span></span></div>
      <span class="terminal-title">opencode / modal-uv</span>
      <span class="terminal-status">session running</span>
    </div>

    <div class="agent-terminal__body">
      <ol class="agent-chat" aria-label="Example coding agent session">
        <li class="chat-row chat-row--prompt">
          <span class="chat-gutter" aria-hidden="true">&gt;</span>
          <div class="chat-line">
            <p>Run the benchmark on a Modal GPU, fix failures, and keep the results.</p>
          </div>
        </li>

        <li class="chat-row chat-row--loading chat-row--agent-loading">
          <span class="chat-gutter" aria-hidden="true">·</span>
          <div class="chat-line chat-line--loading">
            <span class="loading-dots" aria-label="Loading"><i></i><i></i><i></i></span>
          </div>
        </li>

        <li class="chat-row chat-row--agent">
          <span class="chat-gutter" aria-hidden="true">✦</span>
          <div class="chat-line chat-line--block">
            <pre><code>def run_benchmark():
    x = torch.randn(8192, 8192, device="cuda")
    return kernel(x).mean().item()</code></pre>
          </div>
        </li>

        <li class="chat-row chat-row--loading chat-row--tool-loading">
          <span class="chat-gutter" aria-hidden="true">·</span>
          <div class="chat-line chat-line--loading">
            <span class="loading-track"><span></span></span>
          </div>
        </li>

        <li class="chat-row chat-row--tool">
          <span class="chat-gutter" aria-hidden="true">$</span>
          <div class="chat-line chat-line--block">
            <pre><code>$ modal-uv run -- python run_benchmark.py
sync 18 changed files
spawned fc-82a... tailing logs</code></pre>
          </div>
        </li>

        <li class="chat-row chat-row--error">
          <span class="chat-gutter" aria-hidden="true">×</span>
          <div class="chat-line">
            <p>RuntimeError: expected all tensors on cuda:0, got cpu</p>
          </div>
        </li>

        <li class="chat-row chat-row--loading chat-row--fix-loading">
          <span class="chat-gutter" aria-hidden="true">·</span>
          <div class="chat-line chat-line--loading">
            <span class="loading-dots" aria-label="Loading"><i></i><i></i><i></i></span>
          </div>
        </li>

        <li class="chat-row chat-row--agent">
          <span class="chat-gutter" aria-hidden="true">✦</span>
          <div class="chat-line chat-line--block">
            <pre><code>weights = load_weights().to("cuda")
result = kernel(x, weights)</code></pre>
          </div>
        </li>

        <li class="chat-row chat-row--loading chat-row--rerun-loading">
          <span class="chat-gutter" aria-hidden="true">·</span>
          <div class="chat-line chat-line--loading">
            <span class="loading-track"><span></span></span>
          </div>
        </li>

        <li class="chat-row chat-row--success">
          <span class="chat-gutter" aria-hidden="true">✓</span>
          <div class="chat-line chat-line--block">
            <pre><code>$ modal-uv run -- python run_benchmark.py
31.4 ms p50 / logs saved / results persisted</code></pre>
          </div>
        </li>
      </ol>

      <div class="agent-input" aria-hidden="true">
        <span>&gt;</span>
        <span class="agent-input__text">modal-uv logs fc-82a...</span>
        <span class="cursor"></span>
      </div>
    </div>
  </div>
</figure>
